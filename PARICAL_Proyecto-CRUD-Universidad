#include <mysqlx/xdevapi.h>
#include <iostream>
#include <string>
#include <vector>

using namespace std;
using namespace mysqlx;

// --- Prototipos de Funciones ---
void menuAlumnos(Session &session);
void menuCursos(Session &session);
void menuSecciones(Session &session);
void menuAlumnosCursos(Session &session);
void menuAlumnosSeccion(Session &session);
void listarAlumnosCompleto(Session &session);

void limpiarBuffer() {
    cin.ignore(1000, '\n');
}

int main() {
    try {
        // Conexion a la base de datos universidad
        Session session("localhost", 33060, "root", "", "universidad");

        int opcion;
        do {
            cout << "\n=====================================";
            cout << "\n        SISTEMA UNIVERSIDAD          ";
            cout << "\n=====================================";
            cout << "\n1. Alumnos\n2. Cursos\n3. Secciones\n4. Alumnos Cursos";
            cout << "\n5. Alumnos - Seccion\n6. Salir\nOpcion: ";
            cin >> opcion;

            switch(opcion) {
                case 1: menuAlumnos(session); break;
                case 2: menuCursos(session); break;
                case 3: menuSecciones(session); break;
                case 4: menuAlumnosCursos(session); break;
                case 5: menuAlumnosSeccion(session); break;
                case 6: cout << "\nCerrando conexion y saliendo...\n"; break;
                default: cout << "\nOpcion no valida.\n";
            }
        } while(opcion != 6);

    } catch (const Error &e) {
        cerr << "\nERROR DE BASE DE DATOS: " << e << endl;
        return 1;
    }
    return 0;
}

// ================= MODULO ALUMNOS =================
void menuAlumnos(Session &session) {
    int sub;
    do {
        cout << "\n--- MODULO ALUMNOS ---\n1. Listar\n2. Grabar\n3. Modificar\n4. Eliminar\n5. Regresar\nOpcion: ";
        cin >> sub;
        
        if(sub == 1) listarAlumnosCompleto(session);
        else if(sub == 2) {
            // USAMOS std::string para evitar la ambigüedad con mysqlx::string
            std::string n, a, c; 
            cout << "Nombres: "; limpiarBuffer(); getline(cin, n);
            cout << "Apellidos: "; getline(cin, a);
            cout << "Carnet: "; cin >> c;
            session.sql("INSERT INTO alumnos(nombres, apellidos, carnet) VALUES (?,?,?)").bind(n).bind(a).bind(c).execute();
            cout << "Alumno grabado con exito.\n";
        }
        else if(sub == 3) {
            int id; std::string n, a;
            cout << "ID del alumno a modificar: "; cin >> id;
            cout << "Nuevos Nombres: "; limpiarBuffer(); getline(cin, n);
            cout << "Nuevos Apellidos: "; getline(cin, a);
            session.sql("UPDATE alumnos SET nombres=?, apellidos=? WHERE id=?").bind(n).bind(a).bind(id).execute();
            cout << "Datos actualizados.\n";
        }
        else if(sub == 4) {
            int id; cout << "ID a eliminar: "; cin >> id;
            session.sql("DELETE FROM alumnos WHERE id=?").bind(id).execute();
            cout << "Registro eliminado.\n";
        }
    } while(sub != 5);
}

// ================= MODULO CURSOS =================
void menuCursos(Session &session) {
    int sub;
    do {
        cout << "\n--- MODULO CURSOS ---\n1. Listar\n2. Grabar\n3. Modificar\n4. Eliminar\n5. Regresar\nOpcion: ";
        cin >> sub;
        if(sub == 1) {
            RowResult res = session.sql("SELECT * FROM cursos").execute();
            // Especificamos std::string en el .get<>()
            for(Row row : res) cout << row[0] << " | " << row[1].get<std::string>() << " | " << row[2].get<std::string>() << endl;
        }
        else if(sub == 2) {
            std::string n, c;
            cout << "Nombre Curso: "; limpiarBuffer(); getline(cin, n);
            cout << "Codigo: "; cin >> c;
            session.sql("INSERT INTO cursos(nombre, codigo) VALUES (?,?)").bind(n).bind(c).execute();
        }
        else if(sub == 3) {
            int id; std::string n;
            cout << "ID Curso: "; cin >> id;
            cout << "Nuevo Nombre: "; limpiarBuffer(); getline(cin, n);
            session.sql("UPDATE cursos SET nombre=? WHERE id=?").bind(n).bind(id).execute();
        }
        else if(sub == 4) {
            int id; cout << "ID a eliminar: "; cin >> id;
            RowResult check = session.sql("SELECT id FROM alumnos_cursos WHERE curso_id=?").bind(id).execute();
            if(check.count() > 0) cout << "No se puede eliminar: Alumnos asignados a este curso.\n";
            else session.sql("DELETE FROM cursos WHERE id=?").bind(id).execute();
        }
    } while(sub != 5);
}

// ================= MODULO SECCIONES =================
void menuSecciones(Session &session) {
    int sub;
    do {
        cout << "\n--- MODULO SECCIONES ---\n1. Listar\n2. Grabar\n3. Modificar\n4. Eliminar\n5. Regresar\nOpcion: ";
        cin >> sub;
        if(sub == 1) {
            RowResult res = session.sql("SELECT * FROM secciones").execute();
            for(Row row : res) cout << row[0] << " | " << row[1].get<std::string>() << " | " << row[2].get<std::string>() << endl;
        }
        else if(sub == 2) {
            std::string n, j;
            cout << "Nombre Seccion: "; limpiarBuffer(); getline(cin, n);
            cout << "Jornada: "; cin >> j;
            session.sql("INSERT INTO secciones(nombre, jornada) VALUES (?,?)").bind(n).bind(j).execute();
        }
        else if(sub == 4) {
            int id; cout << "ID Seccion: "; cin >> id;
            RowResult check = session.sql("SELECT id FROM alumnos_seccion WHERE seccion_id=?").bind(id).execute();
            if(check.count() > 0) cout << "Error: Seccion tiene alumnos asignados.\n";
            else session.sql("DELETE FROM secciones WHERE id=?").bind(id).execute();
        }
    } while(sub != 5);
}

// ================= ALUMNOS - CURSOS =================
void menuAlumnosCursos(Session &session) {
    int sub;
    do {
        cout << "\n--- ASIGNACION DE CURSOS ---\n1. Listar\n2. Asignar\n3. Eliminar\n4. Regresar\nOpcion: ";
        cin >> sub;
        if(sub == 1) {
            RowResult res = session.sql("SELECT ac.id, a.nombres, c.nombre FROM alumnos_cursos ac JOIN alumnos a ON ac.alumno_id = a.id JOIN cursos c ON ac.curso_id = c.id").execute();
            for(Row row : res) cout << row[0] << " | Alumno: " << row[1].get<std::string>() << " | Curso: " << row[2].get<std::string>() << endl;
        }
        else if(sub == 2) {
            int a_id, c_id;
            cout << "ID Alumno: "; cin >> a_id;
            cout << "ID Curso: "; cin >> c_id;
            RowResult check = session.sql("SELECT id FROM alumnos_cursos WHERE alumno_id=? AND curso_id=?").bind(a_id).bind(c_id).execute();
            if(check.count() > 0) cout << "El alumno ya tiene este curso asignado.\n";
            else session.sql("INSERT INTO alumnos_cursos(alumno_id, curso_id) VALUES (?,?)").bind(a_id).bind(c_id).execute();
        }
        else if(sub == 3) {
            int id; cout << "ID Asignacion a eliminar: "; cin >> id;
            session.sql("DELETE FROM alumnos_cursos WHERE id=?").bind(id).execute();
        }
    } while(sub != 4);
}

// ================= ALUMNOS - SECCION =================
void menuAlumnosSeccion(Session &session) {
    int sub;
    do {
        cout << "\n--- ASIGNACION DE SECCION ---\n1. Listar\n2. Asignar/Cambiar\n3. Eliminar\n4. Regresar\nOpcion: ";
        cin >> sub;
        if(sub == 2) {
            int a_id, s_id;
            cout << "ID Alumno: "; cin >> a_id;
            cout << "ID Seccion: "; cin >> s_id;
            session.sql("DELETE FROM alumnos_seccion WHERE alumno_id=?").bind(a_id).execute();
            session.sql("INSERT INTO alumnos_seccion(alumno_id, seccion_id) VALUES (?,?)").bind(a_id).bind(s_id).execute();
            cout << "Seccion asignada.\n";
        }
        else if(sub == 3) {
            int id; cout << "ID Asignacion a eliminar: "; cin >> id;
            session.sql("DELETE FROM alumnos_seccion WHERE id=?").bind(id).execute();
        }
    } while(sub != 4);
}

// ================= CONSULTA ESPECIAL (JOIN) =================
void listarAlumnosCompleto(Session &session) {
    RowResult res = session.sql(
        "SELECT a.id, a.nombres, a.apellidos, a.carnet, "
        "IFNULL(c.nombre, 'Sin cursos') AS curso, "
        "IFNULL(s.nombre, 'Sin seccion') AS seccion "
        "FROM alumnos a "
        "LEFT JOIN alumnos_cursos ac ON a.id = ac.alumno_id "
        "LEFT JOIN cursos c ON ac.curso_id = c.id "
        "LEFT JOIN alumnos_seccion ase ON a.id = ase.alumno_id "
        "LEFT JOIN secciones s ON ase.seccion_id = s.id"
    ).execute();

    cout << "\n--- LISTADO INTEGRADO DE ALUMNOS ---\n";
    cout << "ID | Nombres | Apellidos | Carnet | Curso | Seccion\n";
    for(Row row : res) {
        cout << row[0] << " | " << row[1].get<std::string>() << " | " << row[2].get<std::string>() << " | " 
             << row[3].get<std::string>() << " | " << row[4].get<std::string>() << " | " << row[5].get<std::string>() << endl;
    }
}


